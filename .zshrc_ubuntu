### ZSH CONFIGURATION ###

# starship.rs prompt setup
export STARSHIP_SHELL=~/.config/starship.toml
eval "$(starship init zsh)"

# run nerdfetch on shell start 
nerdfetch

### HISTORY ##

HISTFILE=~/.zsh_history
HISTSIZE=2000
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_find_no_dups


### KEYBINDINGS ###

bindkey -v
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward



# FZF theme: Tundra -> "gh:sam4llis/nvim-tundra"
export FZF_DEFAULT_OPTS=$FZF_DEFAULT_OPTS'
 --color=fg:#64748b,bg:#111827,hl:#bae6fd
 --color=fg+:#bae6fd,bg+:#111827,hl+:#bae6fd
 --color=info:#b1e3ad,prompt:#b1e3ad,pointer:#bae6fd
 --color=marker:#64748b,spinner:#b1e3ad,header:#b1e3ad'

### ALIAS ### 
# alias source zsh
alias src="source ~/.zshrc"

# alias ls coloring
alias ls="ls --color"

# alias update manjaro - pacman 
alias update="sudo apt update && sudo apt upgrade"

# alias open .zshrc 
alias zshrc="nvim ~/.zshrc"

# alias python
alias py="python3"
alias pip="pip3"

# alias nvim shortcuts
alias vim="nvim"
alias vi="nvim"

# alias nvim in sudo -E
alias svim="sudo -E  /usr/bin/nvim ."

## GIT aliases
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gpl="git pull"
alias gl="git log"
alias gd="git diff"
alias gb="git branch"
alias gco="git checkout"
alias gcl="git clone"
alias gm="git merge"
alias lz="lazygit"
alias lg="lazygit"

### PATHFINDERS ###

export PATH="$PATH:/home/bgx/.cargo/bin"

# nvim appimage
export PATH="$PATH:/opt/nvim/"

# System default editor
export EDITOR=nvim

# bat 
alias bat="batcat"

# Go-lang path 
export GOROOT=/usr/local/go
export GOPATH=$HOME/go
export PATH=$PATH:$GOROOT/bin:$GOPATH/bin
export PATH=$PATH:/usr/local/go/bin

# bat theme
export BAT_THEME="Catpuccin Mocha"

# Zoxide setup - better cd commands
eval "$(zoxide init zsh)"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
